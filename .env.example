# CooMate Environment Configuration

# === LLM Provider Configuration ===
# Anthropic-compatible provider (e.g. MiMo, MiniMax)
# LLM_PROVIDER options: anthropic_messages | openai_compatible
LLM_BASE_URL=https://your-llm-provider-url
LLM_API_KEY=your-api-key-here
LLM_MODEL=your-model-name
LLM_PROVIDER=anthropic_messages

# === Server Configuration ===
HOST=0.0.0.0
PORT=8266
DEBUG=true

# === CORS ===
CORS_ORIGINS=http://localhost:5066,http://localhost:3000,http://127.0.0.1:5066

# === Database (PostgreSQL) ===
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/coomate
